# Copy to server/.env
# MongoDB — local (mongodb://127.0.0.1:27017/superagent) or Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/superagent
# Keep this prototype isolated even when the Atlas URI defaults to /test.
MONGO_DB_NAME=superagent
# Optional fallback for networks that refuse MongoDB Atlas SRV DNS queries.
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# REQUIRED — the server refuses to start without it. Use a long random string
# (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`).
JWT_SECRET=
PORT=5000
# Allowed browser origins for CORS (comma-separated). Default: Vite dev client.
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Deterministic data generation seed for npm run seed / sample-data (default 20260711)
SEED=20260711
# Optional — OpenAI for natural-language alert text. Missing/invalid key => template fallback (demo never breaks).
OPENAI_API_KEY=
